# ─────────────────────────────────────────────
#  UTME SQUAD  –  Environment Variables
#  Copy this file to .env and fill in ALL values
# ─────────────────────────────────────────────

# REQUIRED: Generate with: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=CHANGE_ME_generate_a_long_random_string

# Set to False in production
DEBUG=False

# Comma-separated list of your domain(s)
# Example: ALLOWED_HOSTS=utmesquad.com,www.utmesquad.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────
# Use 'sqlite' for development, 'mysql' for production
DB_ENGINE=mysql
DB_NAME=utme_squad_db
DB_USER=utme_user
DB_PASSWORD=CHANGE_ME_strong_db_password
DB_HOST=localhost
DB_PORT=3306

# ── Redis (required for multi-process WebSocket in production) ────────────────
# Example: redis://127.0.0.1:6379/0   or   redis://:password@host:6379/0
REDIS_URL=redis://127.0.0.1:6379/0

# ── CORS ──────────────────────────────────────
# Comma-separated allowed origins (must match your frontend domain exactly)
# Example: CORS_ORIGINS=https://utmesquad.com,https://www.utmesquad.com
CORS_ORIGINS=https://yourdomain.com

# ── Default Passwords (set before first run, then change via dashboard) ───────
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password
DEFAULT_UNLOCK_PASSWORD=CHANGE_ME_unlock_password
